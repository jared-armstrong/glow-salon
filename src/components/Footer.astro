---
/**
 * Footer component
 * Single Responsibility: Display site footer with navigation, contact, and branding
 */
import { BUSINESS_INFO } from '../config/constants';
import { NAVIGATION_LINKS } from '../config/constants';
import SocialIcons from './SocialIcons.astro';
---

<footer class="footer" role="contentinfo">
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="footer-logo">Glow <em>Salon</em> &amp; Spa</div>
      <p class="footer-tagline">Where beauty meets passion,<br>and every client leaves glowing.</p>
      <div class="footer-social">
        <SocialIcons variant="dark" />
      </div>
    </div>

    <div class="footer-col">
      <div class="footer-col-title">Navigate</div>
      <ul class="footer-links">
        {NAVIGATION_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              {...('external' in link && link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li><a href="/services/bridal">Bridal</a></li>
        <li><a href="/services/hair">Hair</a></li>
        <li><a href="/services/nails">Nails</a></li>
        <li><a href="/services/makeup">Waxing &amp; Makeup</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <div class="footer-col-title">Find Us</div>
      <address class="footer-contact">
        {BUSINESS_INFO.address.street}<br>
        {BUSINESS_INFO.address.city}, {BUSINESS_INFO.address.state} {BUSINESS_INFO.address.zip}<br><br>
        <a href={`tel:${BUSINESS_INFO.phone.replace(/-/g, '')}`}>{BUSINESS_INFO.phoneFormatted}</a>
        <br><br>
        <span class="footer-areas">Serving Carmel, Westfield, Fishers, Noblesville, Zionsville &amp; Indianapolis</span>
      </address>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-bottom-text">© 2026 Glow Salon & Spa · Carmel, Indiana</span>
    <span class="footer-bottom-text">Powered by GlossGenius</span>
  </div>
</footer>

<style>
  .footer {
    background: #2a1e18;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 2rem;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }

  .footer-logo em {
    font-style: italic;
    color: var(--rose);
  }

  .footer-tagline {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    color: var(--warm-gray);
    font-weight: 300;
    line-height: 1.7;
    margin: 0;
  }

  .footer-social {
    margin-top: 1rem;
  }

  .footer-col-title {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: 0.6rem;
  }

  .footer-links a {
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--blush);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--cream);
  }

  .footer-contact {
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--blush);
    line-height: 2;
    opacity: 0.8;
    font-style: normal;
  }

  .footer-contact a {
    color: var(--blush);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact a:hover {
    color: var(--cream);
  }

  .footer-bottom {
    background: #1e1510;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    max-width: 100%;
  }

  .footer-bottom-text {
    font-family: 'Jost', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--warm-gray);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2.5rem 1.25rem;
    }

    .footer-bottom {
      padding: 1rem 1.25rem;
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
