---
/**
 * TeamSection component
 * Single Responsibility: Display team members with portrait card layout
 */
import { teamMembers } from '../data/team';
import jaredImage from '../assets/team/jared.webp';
import lauraImage from '../assets/team/laura_brock.webp';
import juliaImage from '../assets/team/julia_zeffner.webp';
import emilyImage from '../assets/team/emily_saunders.webp';
import hannahImage from '../assets/team/hannah_d.webp';
import { Image } from 'astro:assets';

const imageMap: Record<string, ImageMetadata> = {
  jared: jaredImage,
  laura: lauraImage,
  julia: juliaImage,
  emily: emilyImage,
  hannah: hannahImage,
};
---

<section class="team-section">
  <div class="team-inner">
    <div class="team-heading">
      <p class="section-eyebrow">The people behind the magic</p>
      <div class="team-heading-row">
        <h2 class="section-title">Meet our <em>team.</em></h2>
        <a href="/team" class="team-link">Full Team Profiles →</a>
      </div>
    </div>

    <div class="team-grid">
      {teamMembers.map((member) => {
        const imageSrc = imageMap[member.image] || hannahImage;
        return (
          <div class="team-card">
            <div class="team-card-image">
              <Image
                src={imageSrc}
                alt={`${member.name} - ${member.role} at Glow Salon & Spa`}
                width={400}
                height={533}
                loading="lazy"
                decoding="async"
                quality={85}
                class="team-img"
              />
            </div>
            <div class="team-card-info">
              <div class="team-name">{member.name}</div>
              <div class="team-role">{member.role}</div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 6rem 2rem;
    background: var(--cream);
  }

  .team-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .team-heading {
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    margin: 0 0 0.75rem;
  }

  .team-heading-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--deep);
    margin: 0;
  }

  .section-title em {
    font-style: italic;
    color: var(--rose);
  }

  .team-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--warm-gray);
    text-decoration: none;
    border-bottom: 1px solid var(--blush);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .team-link:hover {
    color: var(--deep);
    border-color: var(--rose);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .team-card {
    display: flex;
    flex-direction: column;
  }

  .team-card-image {
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--blush);
  }

  .team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s ease;
    filter: sepia(5%);
  }

  .team-card:hover .team-img {
    transform: scale(1.04);
  }

  .team-card-info {
    padding: 0.85rem 0 0;
  }

  .team-name {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--deep);
    margin-bottom: 0.2rem;
  }

  .team-role {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--warm-gray);
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .team-section {
      padding: 4rem 1.25rem;
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .team-heading-row {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
