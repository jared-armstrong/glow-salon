---
/**
 * ContactForm component
 * Single Responsibility: Display contact form
 */
import { BUSINESS_INFO } from '../config/constants';
---

<h1 class="contact-form-title">Contact Us</h1>

<form action={`https://formspree.io/f/${BUSINESS_INFO.formspreeId}`} method="POST" class="contact-form">
    <label for="name">
        <input type="text" name="name" placeholder="Name" required>
    </label>

    <label for="email">
        <input type="email" name="email" placeholder="your@email.com" required>
    </label>

    <label for="message">
        <textarea name="message" placeholder="What services are you interested in?" required></textarea>
    </label>

    <button type="submit">Submit</button>
</form>

<style>
    .contact-form-title {
        text-align: center;
        margin-top: 3rem;
        margin-bottom: 0.75rem;
        color: var(--deep);
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-size: clamp(2rem, 3.5vw, 2.75rem);
        font-weight: 300;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        width: 320px;
        margin: auto;
        padding: 1.5rem;
        position: relative;
    }

    input::placeholder,
    textarea::placeholder {
        color: var(--warm-gray);
        font-size: 0.9rem;
    }

    .contact-form input,
    .contact-form textarea {
        width: 100%;
        border: none;
        border-bottom: 2px solid var(--blush);
        padding: 0.65rem 0.25rem;
        font-size: 0.95rem;
        outline: none;
        background: transparent;
        font-family: 'Jost', sans-serif;
        color: var(--deep);
        transition: border-color 0.2s ease;
    }

    .contact-form input:focus,
    .contact-form textarea:focus {
        border-color: var(--rose);
    }

    .contact-form textarea {
        height: 60px;
        resize: none;
    }

    .contact-form button {
        align-self: flex-end;
        background: var(--deep);
        color: var(--cream);
        border: none;
        padding: 0.75rem 1.75rem;
        font-family: 'Jost', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.25s ease;
    }

    .contact-form button:hover {
        background: var(--rose);
    }
</style>
