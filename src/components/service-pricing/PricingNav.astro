<nav class="pricing-nav">
  <a href={Astro.url.pathname === '/' ? '#' : '/'}>Home</a>
  <a href="#hair">Hair</a>
  <a href="#nails">Nails</a>
  <a href="#waxing">Waxing & Makeup</a>
</nav>

<style>
  .pricing-nav {
    display: flex;
    justify-content: center;
    gap: 2rem;
    width: 100%;
    padding: 0.85rem 0;
    background-color: var(--blush);
  }

  .pricing-nav a {
    font-family: 'Jost', sans-serif;
    color: var(--deep);
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 400;
    transition: color 0.2s ease;
    cursor: pointer;
  }

  .pricing-nav a:hover {
    color: var(--rose);
  }
</style>
