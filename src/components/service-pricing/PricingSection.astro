---
/**
 * PricingSection component
 * Single Responsibility: Display individual service pricing information
 */
interface Props {
  serviceName: string;
  description?: string;
  price: string;
}

const { serviceName, description, price } = Astro.props;
---

<div class="service-container">
  <h3 class="service-name">{serviceName}</h3>
  {description && <p class={`description ${description.includes('Travel fee') ? 'travel-fee' : ''}`}>{description}</p>}
  <p class="price">
    {price}
  </p>
</div>


<style>
    .service-container {
        display: flex;
        flex-direction: column;
        width: 90%;
        padding-left: 20px;
        margin-bottom: 0;
    }

    .service-name {
        color: var(--rose);
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-size: 1.15rem;
        font-weight: 400;
        margin-bottom: 0;
        max-width: 85%;
    }

    .description {
        font-family: 'Jost', sans-serif;
        font-size: 0.85rem;
        font-weight: 300;
        color: var(--warm-gray);
        margin-bottom: 0;
    }

    .travel-fee {
        font-family: 'Jost', sans-serif;
        font-size: 0.85rem;
        font-weight: 400;
        color: var(--deep);
    }

    .price {
      font-family: 'Jost', sans-serif;
      font-size: 0.95rem;
      font-weight: 400;
      color: var(--deep);
    }
</style>