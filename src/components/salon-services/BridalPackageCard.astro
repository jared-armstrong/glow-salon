---
/**
 * BridalPackageCard component
 * Single Responsibility: Present a consistent layout for bundled bridal packages
 */
interface Props {
    name: string;
    price: string;
    services: string[];
    bundleValue: string;
    savings: string;
    priceSuffix?: string;
    featured?: boolean;
}

const {
    name,
    price,
    services,
    bundleValue,
    savings,
    priceSuffix,
    featured = false,
} = Astro.props;
---

<div class={`package-card ${featured ? 'featured' : ''}`}>
    <div class="package-header">
        <h3 class="package-name">{name}</h3>
        <div class="package-price">
            {price}
            {priceSuffix && <span class="per-person">{priceSuffix}</span>}
        </div>
    </div>

    <div class="package-content">
        <p class="package-includes">Includes:</p>
        <ul class="package-services">
            {services.map((service) => (
                <li>{service}</li>
            ))}
        </ul>

        <div class="package-savings">
            <span class="bundle-value">{bundleValue}</span>
            <span class="save-amount">{savings}</span>
        </div>
    </div>
</div>

<style>
    .package-card {
        background: white;
        padding: 25px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid var(--blush);
    }

    .package-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(61, 43, 35, 0.1);
    }

    .package-card.featured {
        border: 2px solid var(--rose);
        background: #faf7f2;
    }

    .package-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 1px solid var(--blush);
        gap: 15px;
    }

    .package-name {
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        color: var(--deep);
        font-size: 1.3rem;
        font-weight: 300;
        margin: 0;
        flex: 1;
    }

    .package-card.featured .package-name {
        color: var(--rose);
    }

    .package-price {
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-size: 1.8rem;
        font-weight: 400;
        color: var(--deep);
        white-space: nowrap;
    }

    .per-person {
        font-size: 1rem;
        font-weight: normal;
        margin-left: 4px;
    }

    .package-content {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .package-includes {
        font-family: 'Jost', sans-serif;
        color: var(--warm-gray);
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 400;
        margin: 0;
    }

    .package-services {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .package-services li {
        font-family: 'Jost', sans-serif;
        color: var(--deep);
        font-size: 0.88rem;
        font-weight: 300;
        margin-bottom: 8px;
        line-height: 1.5;
        position: relative;
        padding-left: 20px;
    }

    .package-services li::before {
        content: "✓";
        position: absolute;
        left: 0;
        top: 0;
        color: var(--rose);
        font-weight: 400;
        font-size: 0.9rem;
    }

    .package-savings {
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #f0f0f0;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .bundle-value {
        font-family: 'Jost', sans-serif;
        color: var(--warm-gray);
        font-size: 0.85rem;
        font-weight: 300;
        text-decoration: line-through;
    }

    .save-amount {
        font-family: 'Jost', sans-serif;
        color: var(--rose);
        font-size: 0.9rem;
        font-weight: 400;
    }

    @media (max-width: 480px) {
        .package-card {
            padding: 20px;
        }

        .package-name {
            font-size: 1.1rem;
        }

        .package-price {
            font-size: 1.5rem;
        }
    }
</style>

