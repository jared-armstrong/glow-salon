---
/**
 * BridalBanner component
 * Single Responsibility: Display contextual bridal prompt above services section
 */
import { BUSINESS_INFO } from '../config/constants';
---

<div class="bridal-banner">
  <span class="banner-text">
    ✦ Spring Bridal Trials — Book Now &amp; Save
  </span>
  <a href="/services/bridal" class="banner-link">
    View Bridal Packages →
  </a>
</div>

<style>
  .bridal-banner {
    background: linear-gradient(135deg, var(--deep) 0%, #5a3d32 100%);
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 0.85rem 2rem;
    flex-wrap: wrap;
  }

  .banner-text {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .banner-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--blush);
    text-decoration: none;
    border-bottom: 1px solid var(--rose);
    padding-bottom: 1px;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .banner-link:hover {
    color: #fff;
  }

  @media (max-width: 600px) {
    .bridal-banner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
      padding: 0.85rem 1rem;
    }
  }
</style>
