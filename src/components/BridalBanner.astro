---
/**
 * BridalBanner component
 * Single Responsibility: Display contextual bridal consultation prompt above bridal card
 */
---

<div class="bridal-banner">
  <div class="banner-content">
    <p class="banner-eyebrow">2026 Bridal Season</p>
    <h3>Planning Your Wedding Day Look?</h3>
    <p class="banner-sub">Free 30-minute consultations available. Trials recommended 3–6 months before your date.</p>
    <a href="https://calendly.com/glowsalonwestclay/30min" target="_blank" rel="noopener noreferrer" class="banner-cta">Book a Free Consultation</a>
  </div>
</div>

<style>
  .bridal-banner {
    background: #fdf3ee;
    border: 1px solid #e8d0c0;
    border-radius: 12px;
    margin-bottom: 1.25rem;
  }

  .banner-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.75rem 2rem;
    gap: 0.5rem;
  }

  .banner-eyebrow {
    font-family: 'Poppins', 'Arial', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #b07858;
    margin: 0;
  }

  .banner-content h3 {
    font-family: 'Playfair Display', 'Georgia', serif;
    color: #3d2212;
    margin: 0.25rem 0 0;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .banner-sub {
    color: #7a5a46;
    margin: 0.25rem 0 0.75rem;
    font-size: 0.92rem;
    line-height: 1.5;
    font-family: 'Poppins', 'Arial', sans-serif;
  }

  .banner-cta {
    background: #c9846a;
    color: #fff;
    padding: 0.6rem 1.6rem;
    border-radius: 30px;
    text-decoration: none;
    font-family: 'Poppins', 'Arial', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    transition: background 0.25s ease, transform 0.2s ease;
  }

  .banner-cta:hover {
    background: #b06e54;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .banner-content {
      padding: 1.25rem 1rem;
    }

    .banner-content h3 {
      font-size: 1.25rem;
    }
  }
</style>
