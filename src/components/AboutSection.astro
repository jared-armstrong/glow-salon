---
/**
 * AboutSection component
 * Single Responsibility: Display salon story section with dark editorial layout
 */
import storyImage from '../assets/bridal/IMG_3583.webp';
import { Image } from 'astro:assets';
---

<section class="story">
  <div class="story-image">
    <Image
      src={storyImage}
      alt="Glow Salon & Spa - Our Story"
      loading="lazy"
      decoding="async"
      width={800}
      quality={80}
    />
  </div>
  <div class="story-content">
    <p class="section-eyebrow">Our Story</p>
    <h2 class="section-title">Beauty meets<br><em>passion.</em></h2>
    <p class="story-text">
      Glow Salon & Spa was born in 2013 with a simple mission: to help every client
      look and feel their absolute best. Under new ownership, we're expanding our
      services and enhancing our presence — while our commitment to excellence
      remains unchanged.
    </p>
    <div class="story-stats">
      <div class="story-stat">
        <div class="story-stat-num">2013</div>
        <div class="story-stat-label">Year Founded</div>
      </div>
      <div class="story-stat">
        <div class="story-stat-num">5+</div>
        <div class="story-stat-label">Team Members</div>
      </div>
      <div class="story-stat">
        <div class="story-stat-num">4.6★</div>
        <div class="story-stat-label">Google Rating</div>
      </div>
    </div>
  </div>
</section>

<style>
  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--deep);
    min-height: 420px;
  }

  .story-image {
    position: relative;
    overflow: hidden;
  }

  .story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.88;
    filter: sepia(8%) brightness(0.95);
    display: block;
  }

  .story-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3.5rem 4rem;
  }

  .section-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    margin: 0 0 1rem;
  }

  .section-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--cream);
    margin: 0 0 1.5rem;
  }

  .section-title em {
    font-style: italic;
    color: var(--rose);
  }

  .story-text {
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--blush);
    line-height: 1.8;
    opacity: 0.85;
    margin: 0 0 2.5rem;
  }

  .story-stats {
    display: flex;
    gap: 3rem;
    border-top: 1px solid rgba(184, 154, 122, 0.25);
    padding-top: 2rem;
    flex-wrap: wrap;
  }

  .story-stat-num {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--cream);
    line-height: 1;
  }

  .story-stat-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-top: 0.2rem;
  }

  @media (max-width: 900px) {
    .story {
      grid-template-columns: 1fr;
    }

    .story-image {
      height: 280px;
    }

    .story-content {
      padding: 3rem 2rem;
    }

    .story-stats {
      gap: 2rem;
    }
  }

  @media (max-width: 600px) {
    .story-content {
      padding: 2.5rem 1.25rem;
    }
  }
</style>
