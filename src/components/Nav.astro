---
/**
 * Nav component
 * Single Responsibility: Display main navigation menu
 */
import { NAVIGATION_LINKS } from '../config/constants';

const currentPath = Astro.url.pathname;
---

<nav class="header-nav">
    {NAVIGATION_LINKS.map((link) => (
        <a
            href={link.href}
            class={`nav-link ${'external' in link && link.external ? '' : currentPath === link.href ? 'active' : ''}`}
            {...('external' in link && link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
            {link.label}
        </a>
    ))}
</nav>

<style>
    .header-nav {
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .nav-link {
        font-family: 'Jost', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-weight: 400;
        color: var(--warm-gray);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .nav-link:hover {
        color: var(--deep);
    }

    .nav-link.active {
        color: var(--deep);
    }

    @media (max-width: 768px) {
        .header-nav {
            gap: 1.25rem;
        }

        .nav-link {
            font-size: 0.65rem;
        }
    }

    @media (max-width: 500px) {
        .header-nav {
            display: none;
        }
    }
</style> 