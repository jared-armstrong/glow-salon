---
/**
 * ServicesPreview component
 * Single Responsibility: Display services section on homepage with bridal hero card and 3-card row
 */
import hairServiceImage from '../assets/services/hair.webp';
import nailServiceImage from '../assets/services/nails.webp';
import makeupServiceImage from '../assets/services/IMG_3704rs.webp';
import bridalServiceImage from '../assets/bridal/IMG_3583.webp';
import BridalBanner from './BridalBanner.astro';
import { Image } from 'astro:assets';

const standardServices = [
  {
    image: hairServiceImage,
    name: 'Hair',
    descriptor: 'Color, cuts, balayage & extensions',
    href: '/services/hair',
    alt: 'Haircuts, color, and balayage at Glow Salon & Spa in Carmel, Indiana',
  },
  {
    image: nailServiceImage,
    name: 'Nails',
    descriptor: 'Manicures, pedicures & gel polish',
    href: '/services/nails',
    alt: 'Manicures and pedicures at Glow Salon & Spa in Carmel, Indiana',
  },
  {
    image: makeupServiceImage,
    name: 'Waxing & Glam',
    descriptor: 'Professional waxing & makeup artistry',
    href: '/services/makeup',
    alt: 'Waxing and makeup services at Glow Salon & Spa in Carmel, Indiana',
  },
];
---

<section class="services-preview" id="services">
  <div class="services-inner">

    <div class="services-header">
      <div>
        <p class="section-eyebrow">What We Offer</p>
        <h2 class="section-title">Beauty services<br>done <em>beautifully.</em></h2>
      </div>
      <a href="/services" class="section-link">View All Services</a>
    </div>

    <BridalBanner />

    <div class="services-grid">

      <!-- Bridal featured card -->
      <a href="/services/bridal" class="bridal-card">
        <div class="bridal-card-image">
          <Image
            src={bridalServiceImage}
            alt="Bridal hair and makeup at Glow Salon & Spa in Carmel, Indiana"
            width={800}
            quality={85}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="bridal-card-content">
          <span class="bridal-badge">✦ Featured</span>
          <h3 class="bridal-card-title">Bridal Hair<br><em>& Makeup</em></h3>
          <p class="bridal-card-desc">
            From intimate ceremonies to grand celebrations, our bridal specialists
            craft the look you've always imagined — and make sure it lasts all day.
          </p>
          <span class="btn-outline-light">View Bridal Packages</span>
        </div>
      </a>

      <!-- Three-card row -->
      <div class="services-row">
        {standardServices.map((service) => (
          <a href={service.href} class="service-card">
            <Image
              src={service.image}
              alt={service.alt}
              width={400}
              quality={80}
              loading="lazy"
              decoding="async"
              class="service-img"
            />
            <div class="service-card-overlay">
              <h3 class="service-card-name">{service.name}</h3>
              <p class="service-card-desc">{service.descriptor}</p>
              <span class="service-card-link">Explore</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .services-preview {
    padding: 7rem 2rem;
    background: #fff;
    position: relative;
  }

  .services-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Section header */
  .services-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .section-eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--deep);
    margin: 0;
  }

  .section-title em {
    font-style: italic;
    color: var(--rose);
  }

  .section-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--warm-gray);
    text-decoration: none;
    border-bottom: 1px solid var(--blush);
    padding-bottom: 2px;
    white-space: nowrap;
    margin-bottom: 0.5rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .section-link:hover {
    color: var(--rose);
    border-color: var(--rose);
  }

  /* Grid */
  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Bridal card */
  .bridal-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    background: var(--deep);
    overflow: hidden;
    min-height: 340px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bridal-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(61, 43, 35, 0.2);
  }

  .bridal-card-image {
    overflow: hidden;
    position: relative;
  }

  .bridal-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: sepia(10%) brightness(0.88);
    transition: transform 0.5s ease;
    display: block;
  }

  .bridal-card:hover .bridal-card-image img {
    transform: scale(1.04);
  }

  .bridal-card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 3.5rem;
  }

  .bridal-badge {
    display: inline-block;
    font-family: 'Jost', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rose);
    border: 1px solid var(--rose);
    padding: 0.35rem 0.85rem;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .bridal-card-title {
    font-size: 2.25rem;
    font-weight: 300;
    color: var(--cream);
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .bridal-card-title em {
    font-style: italic;
  }

  .bridal-card-desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--blush);
    line-height: 1.7;
    margin: 0 0 2rem;
    opacity: 0.85;
  }

  .btn-outline-light {
    display: inline-block;
    border: 1px solid var(--rose);
    color: var(--cream);
    padding: 0.75rem 1.75rem;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: background 0.25s ease, color 0.25s ease;
    width: fit-content;
    cursor: pointer;
  }

  .btn-outline-light:hover {
    background: var(--rose);
    color: #fff;
  }

  /* Three-card row */
  .services-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .service-card {
    position: relative;
    overflow: hidden;
    height: 260px;
    text-decoration: none;
    display: block;
    cursor: pointer;
  }

  .service-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(8%) brightness(0.92);
    transition: transform 0.45s ease, filter 0.45s ease;
    display: block;
  }

  .service-card:hover .service-img {
    transform: scale(1.06);
    filter: sepia(15%) brightness(0.78);
  }

  .service-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(61, 43, 35, 0.78) 0%,
      rgba(61, 43, 35, 0.12) 50%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.75rem;
    transition: background 0.35s ease;
  }

  .service-card:hover .service-card-overlay {
    background: linear-gradient(
      to top,
      rgba(61, 43, 35, 0.9) 0%,
      rgba(61, 43, 35, 0.4) 55%,
      rgba(61, 43, 35, 0.08) 100%
    );
  }

  .service-card-name {
    font-size: 1.4rem;
    font-weight: 400;
    color: #fff;
    margin: 0 0 0.3rem;
  }

  .service-card-desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem;
    color: var(--blush);
    font-weight: 300;
    margin: 0 0 0.85rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .service-card:hover .service-card-desc {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--rose);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .service-card-link::after {
    content: '→';
  }

  .service-card:hover .service-card-link {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .bridal-card {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .bridal-card-image {
      height: 280px;
    }

    .bridal-card-content {
      padding: 2rem 2rem;
    }

    .services-row {
      grid-template-columns: 1fr;
    }

    .service-card {
      height: 220px;
    }
  }

  @media (max-width: 600px) {
    .services-preview {
      padding: 4rem 1.25rem;
    }

    .services-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .bridal-card-title {
      font-size: 1.75rem;
    }

    .bridal-card-content {
      padding: 1.75rem 1.5rem;
    }
  }
</style>
