---
/**
 * Header component
 * Single Responsibility: Display site header with logo, navigation, and book now CTA
 */
import Nav from './Nav.astro';
import { BUSINESS_INFO } from '../config/constants';
---

<header role="banner">
    <div class="header-content">
        <a href="/" class="logo-container" aria-label="Glow Salon & Spa — Home">
            <span class="logo-text">Glow <em>Salon</em> &amp; Spa</span>
        </a>

        <Nav role="navigation" aria-label="Main navigation" />

        <a
            href={BUSINESS_INFO.bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="header-book-btn"
        >
            Book Now
        </a>
    </div>
</header>

<style>
    header {
        background-color: rgba(250, 247, 242, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 0 2rem;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(184, 154, 122, 0.15);
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        height: 72px;
    }

    .logo-container {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        text-decoration: none;
    }

    .logo-text {
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-size: 1.45rem;
        font-weight: 400;
        color: var(--deep);
        letter-spacing: 0.01em;
        line-height: 1;
    }

    .logo-text em {
        font-style: italic;
        color: var(--rose);
    }

    .header-book-btn {
        font-family: 'Jost', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--cream);
        background: var(--deep);
        text-decoration: none;
        padding: 0.65rem 1.5rem;
        transition: background 0.25s ease;
        flex-shrink: 0;
    }

    .header-book-btn:hover {
        background: var(--rose);
    }

    /* Mobile responsive */
    @media (max-width: 768px) {
        .header-content {
            height: 60px;
        }

        .logo-text {
            font-size: 1.2rem;
        }

        .header-book-btn {
            padding: 0.55rem 1rem;
            font-size: 0.68rem;
        }
    }
</style>
