---
/**
 * Reusable SectionHeader component
 * Single Responsibility: Display consistent section headers
 */
interface Props {
  text: string;
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  className?: string;
}

const { text, level = 1, className = "" } = Astro.props;
const Tag = `h${level}` as keyof HTMLElementTagNameMap;
---

<Tag class={`section-header ${className}`}>{text}</Tag>

<style>
  .section-header {
    display: flex;
    justify-content: center;
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    color: var(--deep);
    font-weight: 300;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  h1.section-header {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
  }

  h2.section-header {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }

  h3.section-header {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  }

  @media (max-width: 767px) {
    h1.section-header {
      font-size: 2rem;
    }

    h2.section-header {
      font-size: 1.5rem;
    }

    h3.section-header {
      font-size: 1.2rem;
    }
  }
</style>

