---
/**
 * CalendlyButton component
 * Single Responsibility: Display a styled call-to-action button for Calendly scheduling
 */

export interface Props {
    href: string;
    label?: string;
    icon?: string;
    variant?: 'primary' | 'secondary';
    className?: string;
}

const { 
    href, 
    label = "Schedule Consultation", 
    icon = "📅",
    variant = "primary",
    className = ""
} = Astro.props;
---

<a 
    href={href} 
    target="_blank" 
    rel="noopener noreferrer" 
    class:list={["calendly-button", `calendly-button--${variant}`, className]}
>
    <span class="calendly-button__icon">{icon}</span>
    <span class="calendly-button__text">{label}</span>
</a>

<style>
    .calendly-button {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 0.75rem 1.75rem;
        text-decoration: none;
        font-family: 'Jost', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 400;
        transition: all 0.25s ease;
        cursor: pointer;
        min-width: 180px;
        justify-content: center;
    }

    .calendly-button--primary {
        background: var(--rose);
        color: white;
        border: 1px solid var(--rose);
    }

    .calendly-button--primary:hover {
        background: var(--deep);
        border-color: var(--deep);
        transform: translateY(-2px);
    }

    .calendly-button--secondary {
        background: transparent;
        color: var(--deep);
        border: 1px solid var(--deep);
    }

    .calendly-button--secondary:hover {
        background: var(--deep);
        color: var(--cream);
        transform: translateY(-2px);
    }

    .calendly-button:active {
        transform: translateY(0);
    }

    .calendly-button__icon {
        font-size: 1.2rem;
        line-height: 1;
    }

    .calendly-button__text {
        line-height: 1;
    }

    @media (max-width: 768px) {
        .calendly-button {
            padding: 14px 24px;
            min-width: 180px;
            font-size: 0.95rem;
        }
    }

    @media (max-width: 480px) {
        .calendly-button {
            width: 100%;
            max-width: 280px;
        }
    }
</style>

