---
/**
 * BookingButtonGroup component
 * Single Responsibility: Display booking action buttons
 */
import { BUSINESS_INFO } from '../../config/constants';
---

<div class="booking-button-group">
  <a href={`tel:+1${BUSINESS_INFO.phone.replace(/-/g, '')}`} class="booking-button">Call to Book</a>
  <a href={BUSINESS_INFO.bookingUrl} target="_blank" class="booking-button">Book Online</a>
  <a href="/contact" class="booking-button">Contact Us</a>
</div>

<style>
    .booking-button-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        width: 100%;
        max-width: 200px;
    }

    .booking-button {
        display: block;
        width: 100%;
        padding: 0.8rem 1.5rem;
        background: transparent;
        color: var(--deep);
        text-decoration: none;
        font-family: 'Jost', sans-serif;
        font-size: 0.72rem;
        font-weight: 400;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-align: center;
        border: 1px solid var(--deep);
        cursor: pointer;
        transition: background 0.25s ease, color 0.25s ease;
    }

    .booking-button:hover {
        background: var(--deep);
        color: var(--cream);
    }

    @media (max-width: 1024px) {
        .booking-button-group {
            flex-direction: row;
            max-width: none;
            justify-content: center;
            gap: 0.75rem;
        }

        .booking-button {
            flex: 1;
            max-width: 160px;
        }
    }

    @media (max-width: 768px) {
        .booking-button-group {
            flex-direction: column;
            align-items: center;
        }

        .booking-button {
            max-width: 200px;
        }
    }
</style>
