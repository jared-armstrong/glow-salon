---
import ServicePage from '../../components/salon-services/ServicePage.astro';
import { hairFAQs } from '../../data/faqs';

const title = "Hair Services in Carmel, IN | Glow Salon & Spa";
const description = "Professional hair services including haircuts, highlights, balayage, keratin treatments, and more. Serving Carmel, Indiana.";

const hair_services = [
    { serviceName: "Women's Short Haircut & Blow-dry", price: '$55' },
    { serviceName: "Women's Long Haircut & Blow-dry", price: '$65'},
    { serviceName: "Men's Haircut", price: '$35' },
    { serviceName: "Children's Haircut (12 and under)", price: '$30' },
    { serviceName: "Shampoo & Style, Short Hair", price: '$35' },
    { serviceName: "Shampoo & Style, Medium Hair", price: '$45' },
    { serviceName: "Shampoo & Style, Long Hair", price: '$55' },
    { serviceName: "Updo", price: '$60' },
    { serviceName: "Bridal Updo", price: 'Priced upon consultation' },
    { serviceName: "Micro-Link Hair Extensions", price: 'Priced upon consultation' },
    { serviceName: "Full Highlight w/Blow-dry", price: 'Starting at $150' },
    { serviceName: "Partial Highlight w/Blow-dry", price: 'Starting at $135' },
    { serviceName: "Full Highlight w/Haircut", price: 'Starting at $175' },
    { serviceName: "Partial Highlight w/Haircut", price: 'Starting at $155' },
    { serviceName: "New Growth Touch-up w/Blow-dry", price: '$110' },
    { serviceName: "New Growth Touch-up w/Haircut", price: '$140' },
    { serviceName: "Dimensional Color w/Blow-dry", price: 'Starting at $140' },
    { serviceName: "Dimensional Color w/Haircut", price: 'Starting at $165' },
    { serviceName: "All Over Color w/Blowout", price: '$130' },
    { serviceName: "All Over Color w/Haircut", price: '$150' },
    { serviceName: "Color Glaze w/Blow-dry", price: '$70' },
    { serviceName: "Color Glaze w/Haircut", price: '$105' },
    { serviceName: "Balayage", price: 'Priced upon consultation' },
    { serviceName: "Keratin Smoothing Treatment", description: "*Lasts 3-5 months", price: '$275' },
    { serviceName: "Keratin Smoothing Treatment (Express)", description: "*Lasts 4-6 weeks", price: '$150' },
    { serviceName: "Chemical Straightening & Retexturizing", price: 'Priced upon consultation' },
    { serviceName: "Permanent Wave", price: '$120' }
]
---

<ServicePage
    title={title}
    description={description}
    pageTitle="Hair Services in Carmel, IN"
    introText="Expert haircuts, color, balayage, extensions, and keratin treatments at Glow Salon & Spa in Carmel, Indiana. Serving clients from Westfield, Fishers, and greater Indianapolis."
    services={hair_services}
    faqs={hairFAQs}
    galleryHeading="Our Hair Work"
    gallerySubtext="Cuts, colors, and styles by the Glow Salon & Spa team"
    galleryUrl="/services/hair-gallery"
/>

<section class="blog-links-section">
    <h2 class="blog-links-heading">From Our Blog</h2>
    <ul class="blog-links-list">
        <li><a href="/blog/spring-2026-hair-color-trends-indianapolis">Spring 2026 Hair Color Trends: What Our Carmel Stylists Are Booking</a></li>
        <li><a href="/blog/how-to-keep-hair-color-lasting-longer">How to Make Your Hair Color Last Longer Between Visits</a></li>
        <li><a href="/blog/how-to-choose-the-right-haircut">How to Choose the Right Haircut for Your Face Shape</a></li>
    </ul>
</section>

<style>
    .blog-links-section {
        max-width: 720px;
        margin: 0 auto 3rem;
        padding: 2rem;
        border-top: 1px solid var(--blush);
    }

    .blog-links-heading {
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-size: 1.4rem;
        font-weight: 300;
        color: var(--deep);
        margin: 0 0 1rem;
    }

    .blog-links-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .blog-links-list li {
        margin-bottom: 0.6rem;
    }

    .blog-links-list a {
        font-family: 'Jost', sans-serif;
        font-size: 0.9rem;
        font-weight: 300;
        color: var(--rose);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .blog-links-list a:hover {
        color: var(--deep);
    }
</style>
