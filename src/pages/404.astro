---
/**
 * 404 page
 * Single Responsibility: Display a helpful not-found page with navigation links
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found | Glow Salon & Spa" description="The page you're looking for doesn't exist. Visit Glow Salon & Spa in Carmel, Indiana for hair, nail, waxing, and bridal services.">
  <Header />
  <section class="not-found">
    <h1 class="not-found-title">Page Not Found</h1>
    <p class="not-found-text">
      Sorry, we couldn't find the page you're looking for. It may have been moved or no longer exists.
    </p>
    <div class="not-found-links">
      <a href="/" class="not-found-link">Home</a>
      <a href="/services" class="not-found-link">Services</a>
      <a href="/contact" class="not-found-link">Contact Us</a>
      <a href="/blog" class="not-found-link">Blog</a>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .not-found {
    max-width: 600px;
    margin: 0 auto;
    padding: 6rem 2rem;
    text-align: center;
  }

  .not-found-title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 300;
    color: var(--deep);
    margin: 0 0 1.25rem;
  }

  .not-found-text {
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--warm-gray);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  .not-found-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .not-found-link {
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rose);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }

  .not-found-link:hover {
    color: var(--deep);
  }
</style>
