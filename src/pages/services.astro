---
import Layout from '../layouts/Layout.astro';
import SalonServices from '../components/salon-services/SalonServices.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/SEO/Breadcrumbs.astro';
import StructuredData from '../components/SEO/StructuredData.astro';
import { generateServiceListSchema } from '../utils/structuredData';
import { BUSINESS_INFO } from '../config/constants';

const serviceListSchema = generateServiceListSchema();
---

<Layout title="Salon Services in Carmel, Indiana - Hair, Nails, Waxing & Bridal | Glow Salon & Spa" description="Professional hair, nail, waxing, and bridal services at Glow Salon & Spa in Carmel, Indiana. Serving the Village of West Clay, Westfield, Fishers, Noblesville & Indianapolis. Book today.">
  <StructuredData data={serviceListSchema} />
  <Breadcrumbs items={[
    { name: "Home", url: BUSINESS_INFO.website },
    { name: "Services", url: `${BUSINESS_INFO.website}/services` },
  ]} />
  <Header />
  <SalonServices />
  <Footer />
</Layout>
