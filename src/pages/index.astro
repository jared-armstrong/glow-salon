---
/**
 * Homepage
 * Single Responsibility: Display main landing page
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import LandingSection from '../components/LandingSection.astro';
import ServicesPreview from '../components/ServicesPreview.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import AboutSection from '../components/AboutSection.astro';
import Footer from '../components/Footer.astro';

const title = "Best Hair & Nail Salon in Carmel, IN | Glow Salon & Spa";
const description = "Glow Salon & Spa in Carmel, Indiana offers expert haircuts, hair color, balayage, highlights, keratin treatments, manicures, pedicures, waxing, and makeup services. Book your appointment today!";
---

<Layout title={title} description={description}>
  <main>
    <Header />
    <LandingSection />
    <ServicesPreview />
    <ReviewsSection />
    <TeamSection />
    <AboutSection />
  </main>
  <Footer />
</Layout>
