---
/**
 * Homepage
 * Single Responsibility: Display main landing page
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BridalBanner from '../components/BridalBanner.astro';
import LandingSection from '../components/LandingSection.astro';
import ServicesPreview from '../components/ServicesPreview.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import AboutSection from '../components/AboutSection.astro';
import Footer from '../components/Footer.astro';

const title = "Best Hair & Nail Salon in Carmel, IN | Glow Salon & Spa";
const description = "Expert hair color, balayage, haircuts, nails, and bridal beauty at Glow Salon & Spa in Carmel, Indiana. Serving Westfield, Fishers & Indianapolis.";
---

<Layout title={title} description={description} isHomepage={true}>
  <Header />
  <BridalBanner />
  <LandingSection />
  <ServicesPreview />
  <ReviewsSection />
  <TeamSection />
  <AboutSection />
  <Footer />
</Layout>
