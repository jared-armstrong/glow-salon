---
/**
 * Homepage
 * Single Responsibility: Display main landing page
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BridalBanner from '../components/BridalBanner.astro';
import LandingSection from '../components/LandingSection.astro';
import ServicesPreview from '../components/ServicesPreview.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import AboutSection from '../components/AboutSection.astro';
import Footer from '../components/Footer.astro';

const title = "Hair Salon & Spa in Carmel, Indiana | Glow Salon & Spa";
const description = "Full-service hair salon and spa in Carmel, Indiana. Haircuts, color, balayage, nails, waxing, and bridal beauty. Serving Carmel, Westfield, Fishers, Noblesville & Indianapolis.";
---

<Layout title={title} description={description} isHomepage={true}>
  <Header />
  <BridalBanner />
  <LandingSection />
  <ServicesPreview />
  <ReviewsSection />
  <TeamSection />
  <AboutSection />
  <Footer />
</Layout>
